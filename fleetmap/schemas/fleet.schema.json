{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Sanexxxx777/fleetmap/schemas/fleet.schema.json",
  "title": "Fleet map",
  "type": "object",
  "required": ["title", "nodes"],
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "subtitle": { "type": "string", "maxLength": 200 },
    "groups": {
      "type": "array",
      "description": "Hosts/servers. Nodes reference a group by id; ungrouped nodes land in the External lane.",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "label": { "type": "string", "minLength": 1, "maxLength": 60 },
          "note": { "type": "string", "maxLength": 120 }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 80,
      "items": {
        "type": "object",
        "required": ["id", "label", "kind"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/$defs/id" },
          "label": { "type": "string", "minLength": 1, "maxLength": 60 },
          "kind": { "enum": ["process", "feed", "database", "bot", "queue", "web", "external"] },
          "group": { "$ref": "#/$defs/id" },
          "health": { "enum": ["online", "stopped", "errored", "unknown"], "default": "unknown" },
          "note": { "type": "string", "maxLength": 120 },
          "meta": {
            "type": "object",
            "description": "Free-form key/value badges rendered under the label (e.g. pm2 id, memory, uptime).",
            "additionalProperties": { "type": "string", "maxLength": 40 },
            "maxProperties": 6
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "from": { "$ref": "#/$defs/id" },
          "to": { "$ref": "#/$defs/id" },
          "kind": { "enum": ["ws", "http", "db", "tg", "ipc", "file"], "default": "http" },
          "label": { "type": "string", "maxLength": 40 },
          "bidi": { "type": "boolean", "default": false }
        }
      }
    }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]{0,39}$" }
  }
}
